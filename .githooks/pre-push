#!/usr/bin/env sh
set -eu

# Git hooks run in a minimal environment without the user's PATH.
# Locate npm from common install locations before running.
find_npm() {
  # 1. Already on PATH
  if command -v npm >/dev/null 2>&1; then
    command -v npm
    return 0
  fi

  # 2. Homebrew (Apple Silicon / Intel)
  for p in /opt/homebrew/bin/npm /usr/local/bin/npm; do
    if [ -x "$p" ]; then echo "$p"; return 0; fi
  done

  # 3. nvm – pick the current/default version
  NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -f "$NVM_DIR/nvm.sh" ]; then
    # shellcheck disable=SC1090
    . "$NVM_DIR/nvm.sh" --no-use
    _nvm_npm=$(command -v npm 2>/dev/null || true)
    if [ -n "$_nvm_npm" ]; then echo "$_nvm_npm"; return 0; fi
  fi

  # 4. JetBrains-bundled Node (WebStorm / IntelliJ)
  _jb_npm=$(find "$HOME/Library/Application Support/JetBrains" \
    -name npm -path "*/bin/npm" 2>/dev/null | sort | tail -1)
  if [ -n "$_jb_npm" ] && [ -x "$_jb_npm" ]; then
    echo "$_jb_npm"
    return 0
  fi

  # 5. Volta
  if [ -x "$HOME/.volta/bin/npm" ]; then echo "$HOME/.volta/bin/npm"; return 0; fi

  return 1
}

NPM=$(find_npm) || {
  echo "[pre-push] ERROR: npm not found – install Node.js and ensure npm is on PATH."
  exit 1
}

# If node is not already on PATH, derive its location from the npm path and
# prepend it. This handles JetBrains-bundled node where only npm was found.
#
# npm lives at one of:
#   .../versions/X/bin/npm                      → node is in the same dir
#   .../versions/X/lib/node_modules/npm/bin/npm → node is 4 dirs up, then bin/
if ! command -v node >/dev/null 2>&1; then
  _npm_bin_dir=$(dirname "$NPM")
  if [ -x "$_npm_bin_dir/node" ]; then
    # npm is a plain symlink in the bin dir – node is right beside it
    export PATH="$_npm_bin_dir:$PATH"
  else
    # npm is the real script inside lib/node_modules/npm/bin – go up 4 levels
    # to reach the version root, then down into bin/
    _ver_root=$(cd "$_npm_bin_dir/../../../.." 2>/dev/null && pwd) || true
    if [ -n "$_ver_root" ] && [ -x "$_ver_root/bin/node" ]; then
      export PATH="$_ver_root/bin:$PATH"
    fi
  fi
fi

echo "[pre-push] Using npm: $NPM"
echo "[pre-push] Running reliability:prepush..."
"$NPM" run reliability:prepush
