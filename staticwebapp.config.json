{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.js",
      "/*.css",
      "/*.json",
      "/*.html",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.gif",
      "/*.svg",
      "/*.ico",
      "/*.woff",
      "/*.woff2",
      "/*.ttf",
      "/*.eot",
      "/*.xlsx",
      "/*.map",
      "/*.yaml",
      "/*.yml",
      "/CSS/*",
      "/JS Files/*",
      "/HTML Files/*",
      "/HTML Files/tabs/*"
    ]
  },
  "routes": [
    {
      "route": "/",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Cross-Origin-Opener-Policy": "same-origin-allow-popups"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Cross-Origin-Opener-Policy": "same-origin-allow-popups"
      }
    },
    {
      "route": "/auth-popup-callback.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Cross-Origin-Opener-Policy": "same-origin-allow-popups"
      }
    }
  ],
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff"
  },
  "mimeTypes": {
    ".json": "text/json",
    ".js": "application/javascript",
    ".css": "text/css",
    ".html": "text/html"
  }
}
